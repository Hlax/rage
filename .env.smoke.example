# Research Graph Engine — smoke-test profile (placeholders only).
# Copy to .env.smoke.local and adjust on your machine. Never commit .env.smoke.local.
#
# Phase 1 reality check (as of ticket-027):
# - Golden tests and CI must use RGE_LLM_MODE=mock (no Ollama required).
# - Pipeline modules (extract-claims, link-concepts, etc.) currently force mock
#   mode internally even when RGE_LLM_MODE=ollama.
# - Ollama structured tasks are not implemented yet; only health_check is live.
# - OpenAI / OpenRouter / Gemini / Vertex are not wired in this repo yet.
#
# Use this file when you want to probe local Ollama reachability before a future
# live-inference ticket — not for golden tests or public export.

RGE_LLM_MODE=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
RGE_LOCAL_LLM=qwen2.5:7b
RGE_LLM_TIMEOUT_SECONDS=120
RGE_LLM_TEMPERATURE=0
RGE_LLM_SCHEMA_VERSION=0.1.0

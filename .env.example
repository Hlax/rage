# Research Graph Engine: local model runtime settings (placeholders only).
#
# Recommended local files (gitignored):
#   .env.local         — day-to-day developer settings (copy from this file)
#   .env.smoke.local   — optional smoke-test profile (copy from .env.smoke.example)
#
# The repo loader reads an optional root `.env` file (see rge/config.py). Process
# environment variables always override `.env` values. No python-dotenv dependency.
#
# Never commit real secrets, API keys, tokens, or machine-specific paths.
# Never commit `.env.local` or `.env.smoke.local`.

# --- Core model runtime ---

# Local Ollama model service (runs outside this repo).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default local instruction model served by Ollama (model tag, not a filesystem path).
# Examples: qwen2.5:7b (general instruct), qwen3.5:9b-q4_K_M (quantized), qwen2.5-coder:7b.
# Run `ollama list` and align RGE_LOCAL_LLM with a pulled tag, or `ollama pull <tag>`.
RGE_LOCAL_LLM=qwen2.5:7b

# Model client mode: "mock" (deterministic fixtures) or "ollama" (live boundary only).
# Use mock for golden tests, fixture runs, and daily development.
# The registry fails closed on any other value. No silent fallback.
RGE_LLM_MODE=mock

# Mode that golden tests force. Tests must never silently call live Ollama.
RGE_TEST_LLM_MODE=mock

# Explicit opt-in for live structured Ollama calls in pipeline modules.
# Requires RGE_LLM_MODE=ollama AND RGE_ALLOW_LIVE_LLM=1. Default off (fail closed).
RGE_ALLOW_LIVE_LLM=0

RGE_LLM_TIMEOUT_SECONDS=60
RGE_LLM_TEMPERATURE=0

# Versioned candidate-output schema expected by parsers/validators.
RGE_LLM_SCHEMA_VERSION=0.1.0

# --- Phase 3 source network (OpenAlex discover/fetch) ---

# Explicit opt-in for source discovery provider network calls.
# Default off (fail closed). Required for discover-sources --provider openalex.
RGE_ALLOW_SOURCE_NETWORK=0

# Polite contact for OpenAlex API (recommended; not a secret).
# OPENALEX_MAILTO=you@example.com

# Optional OpenAlex API key if using authenticated tier. Never commit real keys.
# OPENALEX_API_KEY=

# --- Staged spine mock-fixture operator proofs (live OpenAlex + mock LLM) ---
# Separate from per-step live Ollama gates below. See README Operator Quickstart.

# RGE_ALLOW_LIVE_STAGED_FETCH=0
# RGE_ALLOW_LIVE_STAGED_INGEST=0
# RGE_ALLOW_LIVE_STAGED_EXTRACT=0
# RGE_ALLOW_LIVE_STAGED_LINK=0
# RGE_ALLOW_LIVE_STAGED_BUILD=0
# RGE_ALLOW_LIVE_STAGED_DETECT=0
# Reconcile (network spine only; ticket-184): score_reconciler.py is deterministic Python — no *_LIVE_LLM gate
# RGE_ALLOW_LIVE_STAGED_RECONCILE=0
# Report (network spine only; ticket-187): run_evaluator.py is deterministic Python — no *_LIVE_LLM gate
# RGE_ALLOW_LIVE_STAGED_REPORT=0
# RGE_ALLOW_LIVE_STAGED_RANK2=0
# RGE_ALLOW_LIVE_STAGED_ORCHESTRATOR=0

# --- Per-step live Ollama on staged rank-1 ingest (operator opt-in; not CI) ---
# Each gate is separate from its mock-fixture counterpart above.
# Requires RGE_LLM_MODE=ollama, RGE_ALLOW_LIVE_LLM=1, temp --db (not default graph DB).
# Staged orchestrator (execute_staged_fixture_mode_run) always forces mock LLM.

# Live extract: extract-claims --live-staged-fallthrough (ticket-204)
# RGE_ALLOW_LIVE_STAGED_EXTRACT_LIVE_LLM=0

# Live rank-2 extract: extract-claims --live-staged-rank2-extract-fallthrough (ticket-230)
# RGE_ALLOW_LIVE_STAGED_RANK2_EXTRACT_LIVE_LLM=0

# Live link: link-concepts --live-staged-link-fallthrough (ticket-208)
# RGE_ALLOW_LIVE_STAGED_LINK_LIVE_LLM=0

# Live rank-2 link: link-concepts --live-staged-rank2-link-fallthrough (ticket-236)
# RGE_ALLOW_LIVE_STAGED_RANK2_LINK_LIVE_LLM=0

# Live build: build-relationships --live-staged-build-fallthrough (ticket-212)
# RGE_ALLOW_LIVE_STAGED_BUILD_LIVE_LLM=0

# Live detect: detect-contradictions --live-staged-detect-fallthrough (ticket-217)
# RGE_ALLOW_LIVE_STAGED_DETECT_LIVE_LLM=0
# No live Ollama gates exist for reconcile-scores or generate-run-report (deterministic Python; tickets 184/187).

# --- Embeddings (not used in Phase 1; documented for later phases) ---

RGE_EMBEDDING_MODE=local_sentence_transformer
RGE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

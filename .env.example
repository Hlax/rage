# Research Graph Engine: local model runtime settings.
# Copy to .env and adjust locally. Never commit .env.

# Local Ollama model service (runs outside this repo).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default local instruction model served by Ollama.
RGE_LOCAL_LLM=qwen2.5:7b

# Model client mode: "ollama" (live local runtime) or "mock" (deterministic fixtures).
# The registry fails closed on any other value. No silent fallback.
RGE_LLM_MODE=ollama

# Mode that golden tests force. Tests must never silently call live Ollama.
RGE_TEST_LLM_MODE=mock

RGE_LLM_TIMEOUT_SECONDS=60
RGE_LLM_TEMPERATURE=0

# Versioned candidate-output schema expected by parsers/validators.
RGE_LLM_SCHEMA_VERSION=0.1.0

# Embedding runtime (not used in Phase 0; documented for later phases).
RGE_EMBEDDING_MODE=local_sentence_transformer
RGE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
